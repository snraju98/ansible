- name: demo on error handiling
  hosts: local
  connection: local
  #become: yes
  tasks:
  - name: check roboshop user exists or not
    command: id roboshop
    register: user_output
    ignore_errors: true

  - name: print user_output
    debug:
      msg: "{{ user_output }}"

  - name: create user
    command: useradd roboshop
    when: user_output.rc !=0